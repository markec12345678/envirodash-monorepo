# EnviroDash Environment Variables

# Database (choose one):
# SQLite (default, no setup needed):
DATABASE_URL=file:/app/data/envirodash.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://envirodash:password@localhost:5432/envirodash?schema=public

# Required: MapTiler API key (free at https://cloud.maptiler.com/)
NEXT_PUBLIC_MAPTILER_KEY=your_maptiler_api_key_here

# Required: NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=change-this-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# Optional: OAuth providers (uncomment and fill to enable)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# Optional: Alerts WebSocket service URL (defaults to localhost:3003)
ALERTS_WS_URL=http://localhost:3003

# Optional: Production deployment URL
# NEXT_PUBLIC_APP_URL=https://envirodash.example.com

# Optional: Sentry error tracking (https://sentry.io)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ORG=your-org
# SENTRY_PROJECT=envirodash
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Optional: App version (for Sentry release tracking)
# NEXT_PUBLIC_APP_VERSION=1.0.0
