# EnviroDash Environment Variables

# Required
DATABASE_URL=file:/app/data/envirodash.db
NEXT_PUBLIC_MAPTILER_KEY=your_maptiler_api_key_here

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=change-this-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# Optional: OAuth providers (uncomment and fill to enable)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# Optional: Alerts WebSocket service URL (defaults to localhost:3003)
ALERTS_WS_URL=http://localhost:3003

# Optional: Production deployment URL
# NEXT_PUBLIC_APP_URL=https://envirodash.example.com
