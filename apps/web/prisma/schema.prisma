// EnviroDash Prisma Schema
//
// Supports both SQLite (development) and PostgreSQL (production).
// Switch via DATABASE_URL in .env:
//   SQLite:      DATABASE_URL=file:./db/dev.db
//   PostgreSQL:  DATABASE_URL=postgresql://user:pass@localhost:5432/envirodash
//
// To switch providers, change the `provider` value below.
// For PostgreSQL with PostGIS, use provider = "postgresql" and
// enable native spatial types (see commented lines).

generator client {
  provider = "prisma-client-js"
  // For PostgreSQL with PostGIS extension, enable the preview feature:
  // previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  // Change to "postgresql" for production
  provider = "sqlite"
  url      = env("DATABASE_URL")
  // For PostgreSQL with PostGIS:
  // provider       = "postgresql"
  // url            = env("DATABASE_URL")
  // extensions     = [postgis]
}

// ==================== User & Auth ====================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  image        String?
  role         String   @default("user") // admin | user
  tenantId     String   @default("default")
  plan         String   @default("free") // free | pro | enterprise
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  apiKeys      ApiKey[]
  geofences    Geofence[]
  dashboard    Dashboard?
  installedMonitors UserMonitor[]

  @@index([tenantId])
  @@index([email])
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String
  name         String
  keyHash      String   @unique // SHA-256 hash of the API key
  keyPrefix    String   // First 14 chars for display (ed_live_xxx...)
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?
  requestCount Int      @default(0)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
}

// ==================== Geofences ====================

model Geofence {
  id           String   @id @default(cuid())
  userId       String
  name         String
  lat          Float
  lng          Float
  radiusKm     Float    @default(50)
  thresholds   String   // JSON string: { aqi?: number, fwi?: number, magnitude?: number, sst?: number }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // For PostgreSQL with PostGIS, replace lat/lng with a geometry point:
  // location     Unsupported("geometry(Point, 4326)")?
  // And add a spatial index:
  // @@index([location], type: Gist)
}

// ==================== Custom Dashboard ====================

model Dashboard {
  userId       String   @id
  cards        String   // JSON array of { id, type, title, params, order }
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== Installed Monitors (per user) ====================

model UserMonitor {
  userId       String
  monitorId    String   // e.g. "air-quality", "wildfire"
  installedAt  DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, monitorId])
  @@index([userId])
}

// ==================== Locations (saved by users) ====================

model Location {
  id           String   @id @default(cuid())
  userId       String?
  name         String
  description  String?
  lat          Float
  lng          Float
  category     String   @default("general")
  color        String   @default("#10b981")
  icon         String   @default("map-pin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // For PostgreSQL with PostGIS:
  // location     Unsupported("geometry(Point, 4326)")?
  // @@index([location], type: Gist)

  @@index([userId])
  @@index([category])
}

// ==================== Map Styles ====================

model MapStyle {
  id           String   @id @default(cuid())
  name         String
  url          String
  thumbnail    String?
  isDefault    Boolean  @default(false)
  category     String   @default("custom")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==================== Saved Routes ====================

model Route {
  id           String   @id @default(cuid())
  name         String
  description  String?
  color        String   @default("#3b82f6")
  distance     Float?
  duration     Float?
  waypoints    String   // JSON string of [lng, lat] pairs
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==================== Alerts Log (for audit) ====================

model AlertLog {
  id           String   @id @default(cuid())
  type         String   // earthquake | tsunami | air-quality | wildfire | volcano
  severity     String   // warning | critical
  title        String
  description  String?
  location     String?  // JSON: { name, lat, lng }
  value        Float?
  unit         String?
  source       String
  triggeredAt  DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([triggeredAt])
}
