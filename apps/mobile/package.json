{
  "name": "@envirodash/mobile",
  "version": "1.0.0",
  "private": true,
  "description": "EnviroDash mobile app — real-time environmental monitoring on the go",
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "expo build:android -t apk",
    "build:ios": "expo build:ios -t archive",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf node_modules .expo dist"
  },
  "dependencies": {
    "@envirodash/core": "*",
    "expo": "~52.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-location": "~17.0.0",
    "expo-notifications": "~0.28.0",
    "expo-secure-store": "~14.0.0",
    "expo-linear-gradient": "~13.0.0",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-safe-area-context": "4.14.0",
    "react-native-screens": "~4.4.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.0",
    "react-native-vector-icons": "^10.0.0",
    "@expo/vector-icons": "^14.0.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.0",
    "typescript": "^5.7.2"
  }
}
